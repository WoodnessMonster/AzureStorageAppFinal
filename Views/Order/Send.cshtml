@{
    ViewData["Title"] = "Send Order Message";
}

<h2>Send Order Message</h2>

<form asp-action="Send" method="get">
    <input type="text" name="message" placeholder="Order message" required />
    <button type="submit">Send</button>
</form>

@if (ViewBag.Status != null)
{
    <p>@ViewBag.Status</p>
}
